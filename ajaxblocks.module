<?php

/**
 * @file
 * Loads dynamic blocks on cached page for anonymous users by performing AJAX request.
 */

/**
 * Implements hook_menu().
 */
function ajaxblocks_menu() {
  $items = array();
  $items['ajaxblocks'] = array(
    'page callback' => 'ajaxblocks_ajax_handler',
    'delivery callback' => 'htmx_deliver',
    'access arguments' => array('access content'),
    'type' => MENU_CALLBACK,
  );

  return $items;
}

/**
 * Implements hook_form_FORM_ID_alter().
 * Adds AJAX settings to the block configure page.
 */
function ajaxblocks_form_layout_block_configure_form_alter(&$form, &$form_state) {
  $form['ajaxblocks'] = array(
    '#type' => 'details',
    '#summary' => t('AJAX settings'),
    '#details' => t('The settings for renewing the block content via AJAX.'),
    '#tree' => TRUE,
  );

  if (($form_state['block']->module == 'system' && $form_state['block']->delta == 'main')) {
    $form['ajaxblocks']['no'] = array(
      '#type' => 'markup',
      '#markup' => t('The main page content block cannot be refreshed.'),
    );
    return;
  }

  $settings = array();
  if (isset($form_state['block']->settings['ajaxblocks'])) {
    $settings = $form_state['block']->settings['ajaxblocks'];
  }

  if (module_exists('authcache')) {
    $form['ajaxblocks']['warning'] = array(
      '#type' => 'markup',
      '#value' => t('Authcache module is installed. Please check <a href="@settings">settings</a> and make sure it does not cache AJAX requests to page (Backdrop path) "ajaxblocks".',
        array('@settings' => url('admin/config/development/performance/authcache'))),
    );
  }

  $form['ajaxblocks']['on_load'] = array(
    '#type' => 'checkbox',
    '#title' => t('On page load'),
    '#description' => t('When checked, the content of this block will be refreshed every time the page loads. This will load uncached content.'),
    '#default_value' => isset($settings['on_load']) ? $settings['on_load'] : 0,
  );

  $form['ajaxblocks']['delay'] = array(
    '#type' => 'radios',
    '#title' => t('When to load the block'),
    '#options' => array(
      0 => t('As soon as possible'),
      1 => t('When block is in view'),
    ),
    '#default_value' => isset($settings['delay']) ? $settings['delay'] : 0,
    '#states' => array(
      'visible' => array(
        ':input[name="ajaxblocks[on_load]"]' => array('checked' => TRUE),
      ),
    ),
  );
  $form['ajaxblocks']['delay'][0]['#description'] = t('Will load block as soon as the page is loaded.');
  $form['ajaxblocks']['delay'][1]['#description'] = t('Will load block will wait until the block is revealed in the viewport.');

  $form['ajaxblocks']['delay_time'] = array(
    '#type' => 'number',
    '#min' => 0,
    '#title' => t('Time in seconds to wait before block loading'),
    '#description' => t('You can further defer block loading by a set time.'),
    '#default_value' => isset($settings['delay_time']) ? intval($settings['delay_time']) : 0,
    '#states' => array(
      'visible' => array(
        ':input[name="ajaxblocks[on_load]"]' => array('checked' => TRUE),
      ),
    ),
  );

  $form['ajaxblocks']['reload'] = array(
    '#type' => 'checkbox',
    '#title' => t('Reload'),
    '#description' => t('Choose to reload the block every few seconds.'),
    '#default_value' => isset($settings['reload']) ? $settings['reload'] : 0,
  );
  $form['ajaxblocks']['reload_time'] = array(
    '#type' => 'number',
    '#min' => 1,
    '#title' => t('Time in seconds between loading'),
    '#default_value' => isset($settings['reload_time']) ? intval($settings['reload_time']) : 5,
    '#states' => array(
      'visible' => array(
        ':input[name="ajaxblocks[reload]"]' => array('checked' => TRUE),
      ),
    ),
  );

  $form['ajaxblocks']['manual_reload'] = array(
    '#type' => 'checkbox',
    '#title' => t('Renew content manually'),
    '#description' => t('When checked, the content of this block may be renew manually by clicking a button in the block header.'),
    '#default_value' => isset($settings['manual_reload']) ? $settings['manual_reload'] : 0,
  );

  $form['ajaxblocks']['roles'] = array(
    '#type' => 'details',
    '#summary' => t('Roles'),
    '#details' => t('Restrict which roles for which the block will refresh.'),
    '#collapsible' => TRUE,
    '#collapsed' => TRUE,
  );

  $all_roles = user_roles();

  $form['ajaxblocks']['roles']['cached_roles'] = array(
    '#type' => 'checkboxes',
    '#title' => t('Load the block on cached pages for these roles only'),
    '#description' => t('Only anonymous role is necessary to be selected for most cases.'),
    '#options' => $all_roles,
    '#default_value' => isset($settings['roles']['cached_roles']) ? $settings['roles']['cached_roles'] : array('anonymous', 'authenticated'),
  );

  $form['ajaxblocks']['roles']['uncached_roles'] = array(
    '#type' => 'checkboxes',
    '#title' => t('Load the block on uncached pages for these roles only'),
    '#description' => t("Don't select any role unless you use authcache module or want to load this block via AJAX even on uncached pages."),
    '#options' => $all_roles,
    '#default_value' => isset($settings['roles']['uncached_roles']) ? $settings['roles']['uncached_roles'] : array('anonymous', 'authenticated'),
  );

  array_unshift($form['#submit'], 'ajaxblocks_save_settings');
}

/**
 * Additional submit handler for block settings form.
 * Saves AJAX settings for the block.
 */
function ajaxblocks_save_settings($form, &$form_state) {
  if (!isset($form_state['values'])) {
    return;
  }

  $settings = array();
  if (isset($form_state['block']->settings['ajaxblocks'])) {
    $settings = $form_state['block']->settings['ajaxblocks'];
  }

  if (($form_state['values']['ajaxblocks']['on_load'] == 0 &&
    $form_state['values']['ajaxblocks']['reload'] == 0 &&
    $form_state['values']['ajaxblocks']['manual_reload'] == 0)) {
    // Remove all block settings if disabled.
    $form_state['block']->settings['ajaxblocks'] = array();
  }
  else {
    if (is_null($settings)) {
      $settings = array();
    }

    $form_state['block']->settings['ajaxblocks'] = $form_state['values']['ajaxblocks'];
  }
}

/**
 * Handles AJAX request and returns the content of the appropriate blocks.
 *
 * @return string
 */
function ajaxblocks_ajax_handler() {
  $block_id = $_GET['block_id'] ?? NULL;
  if (!$block_id) {
    return '';
  }
  // Disable client-side caching.
  header('Cache-Control: private, no-cache, no-store, must-revalidate, max-age=0');
  header('Pragma: no-cache');
  // Disable page caching.
  backdrop_page_is_cacheable(FALSE);

  list($module, $delta, $uuid) = explode(':', $block_id);

  $block = layout_create_handler('block', "$module:$delta", array());
  $block->uuid = $uuid;
  $build = layout_get_render_block($block);

  // Only updating the block content, ignore the title.
  return backdrop_render($build['content']);
}

/**
 * Generate an array for rendering a given block.
 *
 * @param Block $block
 *
 * @return array
 *   An array as expected by backdrop_render().
 *
 * @todo remove if a similar generic function appears in core.
 * @see Issue #6893
 */
function ajaxblocks_get_render_block(Block $block) {
  $block->prepare();
  $content = $block->getContent();

  $title = '';
  if ($block->settings['title_display'] !== LAYOUT_TITLE_NONE) {
    $title = $block->getTitle();
  }

  $data = array(
    'title' => $title,
    'content' => $content,
  );

  // Allow altering of the title and content by other modules.
  backdrop_alter(array('block_view', 'block_view_' . $block->module . '_' . str_replace('-', '_', $block->delta)), $data, $block);

  // Assemble a structured content array.
  return array(
    'title' => $data['title'],
    'content' => $data['content'],
  );
}

/**
 * Returns TRUE if current page will be cached (for anonymous or for authenticated users)
 * by Backdrop core or by contrib modules (boost and authcache are supported).
 *
 * @return bool
 */
function ajaxblocks_page_cacheable() {
  static $page_cacheable = NULL;
  if (!is_null($page_cacheable)) {
    return $page_cacheable;
  }
  if (!backdrop_page_is_cacheable()) {
    $page_cacheable = FALSE;
    return $page_cacheable;
  }
  if ((module_exists('boost')) && (isset($GLOBALS['_boost'])) && (isset($GLOBALS['_boost']['cache_this'])) && ($GLOBALS['_boost']['cache_this'])) {
    //TODO check 403 and 404 for Boost: boost_get_http_status 403 404 for anon -> uncached
    $page_cacheable = TRUE;
    return $page_cacheable;
  }
  if ((module_exists('authcache')) && (isset($GLOBALS['is_page_authcache'])) && ($GLOBALS['is_page_authcache'])) {
    //TODO check 403 and 404 for authcache:  (variable_get('authcache_http200', FALSE) && _authcache_get_http_status() != 200)
    $page_cacheable = TRUE;
    return $page_cacheable;
  }
  $page_cacheable = (($GLOBALS['user']->uid == 0) && (config_get('system.core', 'cache')));
  return $page_cacheable;
}

/**
 * Implements hook_preprocess_block().
 */
function ajaxblocks_preprocess_block(&$variables) {
  $id = $variables['block']->module . ':' . $variables['block']->delta . ':' . $variables['block']->uuid;
  if (empty($variables['block']->settings['ajaxblocks'])) {
    return;
  }

  $settings = $variables['block']->settings['ajaxblocks'];

  if (empty($settings['on_load']) && empty($settings['reload']) && empty($settings['manual_reload'])) {
    return;
  }

  $current_user_rids = $GLOBALS['user']->roles;
  if ((ajaxblocks_page_cacheable())) {
    if (count(array_intersect($current_user_rids, $settings['roles']['cached_roles'])) == 0) {
      return;
    }
  }
  else {
    if (count(array_intersect($current_user_rids, $settings['roles']['uncached_roles'])) == 0) {
      return;
    }
  }

  $trigger_vals = array();

  if ($settings['on_load'] == 1) {
    $delay_time = !empty($settings['delay_time']) ? ' delay:' . $settings['delay_time'] . 's' : '';
    $trigger_vals[] = 'load' . $delay_time;
    if ($settings['delay'] == 1) {
      $trigger_vals[] = 'revealed' . $delay_time;
    }
  }

  if ($settings['reload']) {
    $trigger_vals[] = 'every ' . $settings['reload_time'] . 's';
  }

  $build['htmx'] = array(
    '#type' => 'container',
    '#attributes' => array(
      'class' => array('ajaxblocks'),
      'hx-get' => '/ajaxblocks',
      'hx-target' => 'next .block-content',
      'hx-vals' => json_encode(array(
        'block_id' => $id,
      )),
    ),
  );

  if ($settings['manual_reload']) {
    $trigger_vals[] = 'click';
    $build['htmx']['manual_link'] = array(
      '#type' => 'button',
      '#value' => t('Refresh')
    );
  }

  $build['htmx']['#attributes']['hx-trigger'] = implode(', ', $trigger_vals);

  $variables['title_suffix'] = backdrop_render($build);

  if ($settings['on_load'] == 1) {
    // Add an indicator. Need to replace the content since the point is to show
    // fresh content and not the default, possibly cached, content.
    $noscript = '<script type="text/javascript"></script><noscript>' . $variables['content']['#markup'] . '</noscript>';
    $throbber = '<img class="ajaxblocks-throbber js-show" src="'. backdrop_get_path('module', 'ajaxblocks') . '/images/throbber.svg"/>';
    $variables['content']['#markup'] = $noscript . $throbber;
  }
}

/**
 * Implements hook_preprocess_page().
 */
function ajaxblocks_preprocess_page(&$variables) {
  backdrop_add_library('htmx', 'htmx', TRUE);
  backdrop_add_css(backdrop_get_path('module', 'ajaxblocks') . '/css/ajaxblocks.css');
}
